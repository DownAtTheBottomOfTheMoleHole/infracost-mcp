{
  "name": "@downatthebottomofthemolehole/infracost-mcp-server",
  "version": "0.1.0",
  "mcpName": "io.github.DownAtTheBottomOfTheMoleHole/infracost",
  "description": "MCP server for Infracost CLI integration - cloud cost estimates for Infrastructure as Code",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "infracost-mcp-server": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "mcp.json",
    "README.md",
    "LICENSE"
  ],
  "mcp": {
    "name": "infracost",
    "description": "Infracost CLI integration via MCP for cloud cost estimates"
  },
  "keywords": [
    "mcp",
    "infracost",
    "cloud-cost",
    "iac",
    "terraform",
    "cloudformation",
    "finops"
  ],
  "author": "Carl Dawson",
  "repository": "https://github.com/DownAtTheBottomOfTheMoleHole/infracost-mcp",
  "homepage": "https://github.com/DownAtTheBottomOfTheMoleHole/infracost-mcp",
  "bugs": {
    "url": "https://github.com/DownAtTheBottomOfTheMoleHole/infracost-mcp/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:links": "npx --yes markdown-link-check -c .markdown-link-check.json README.md docs/*.md"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "8.57.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "license": "MIT"
}
