{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeDigest",
    ":automergePatch",
    ":automergeBranch",
    "group:allNonMajor"
  ],
  "labels": [
    "dependencies"
  ],
  "assignees": [
    "DownAtTheBottomOfTheMoleHole"
  ],
  "schedule": [
    "before 6am on Monday"
  ],
  "timezone": "UTC",
  "packageRules": [
    {
      "description": "Group all non-major updates together",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Pin GitHub Actions to SHA",
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "GitHub Actions",
      "automerge": true
    },
    {
      "description": "TypeScript ecosystem - major updates require review",
      "matchPackageNames": [
        "typescript",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "typescript",
        "breaking-change"
      ]
    },
    {
      "description": "MCP SDK - major updates require review",
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "mcp-sdk",
        "breaking-change"
      ]
    },
    {
      "description": "Node.js version updates",
      "matchPackageNames": [
        "node",
        "@types/node"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "nodejs",
        "breaking-change"
      ]
    },
    {
      "description": "DevDependencies can be more aggressive with updates",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "assignees": [
      "@DownAtTheBottomOfTheMoleHole"
    ]
  },
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "stabilityDays": 3,
  "commitMessagePrefix": "chore(deps):"
}
